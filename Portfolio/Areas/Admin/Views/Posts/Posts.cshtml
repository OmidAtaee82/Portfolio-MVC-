@model List<AboutMe>

@{
    ViewBag.Title = "posts";
}


<div class="container-84-h-auto">

    <div class="col-lg-11 d-lg-flex justify-content-lg-between align-items-lg-center" style="margin: auto;margin-top: 75px">

        <div class="text-white">
            <h3>Posts</h3>
            <h5>Lorem ipsum dolor sit amet, consectetur.</h5>
        </div>

        <div class="d-lg-flex gap-4 align-items-lg-center">

            <div class="input-search shadow-lg" style="border: 2px solid #222a33">
                <div class="icon-search"></div>
                <input type="text" class="search" placeholder="search contact" />
            </div>

            <a asp-area="admin" asp-controller="posts" asp-action="PostCreate" class="text-decoration-none text-white rounded-2" style="background-color: #6538ed;padding: 10px 15px 10px 15px;">
                <i class="fa fa-plus"></i>New Posts
            </a>

        </div>

    </div>

    <div class="shadow-lg text-white p-3 m-auto mt-4" style="width: 95%">

        <table class="table align-middle table-hover m-auto rounded-3">

            <thead>
                <tr>
                    <th class="th">Id</th>
                    <th class="th">Name</th>
                    <th class="th">Email</th>
                    <th class="th">Location</th>
                    <th class="th">Freelancer</th>
                    <th class="th">Description</th>
                    <th class="th">Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach(var item in Model)
                {
                    <tr>
                        <td class="td">@item.Id</td>
                        <td class="td">@item.Name</td>
                        <td class="td">@item.Email</td>
                        <td class="td">@item.Location</td>
                        <td class="td">
                            <span class="rounded-2 fw-bold (@item.Frelancer ? freelancer_true : freelancer_false)">@item.Frelancer</span>
                        </td>
                        <td class="td">@item.Description</td>
                        <td class="td">

                            <div class="d-lg-flex gap-2">

                                <a href="#">
                                    <div class="d-lg-flex align-items-lg-center justify-content-lg-center rounded-2" style="width: 30px;height: 30px;background-color: #010133">
                                        <svg style="color: #6a6af8" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="25" height="25">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                        </svg>
                                    </div>
                                </a>

                                <a href="#">
                                    <div class="d-lg-flex align-items-lg-center justify-content-lg-center rounded-2" style="width: 30px;height: 30px;background-color: #413d02">
                                        <svg style="color: yellow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="25" height="25">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                                        </svg>
                                    </div>
                                </a>

                                <a href="#">
                                    <div class="d-lg-flex align-items-lg-center justify-content-lg-center rounded-2" style="width: 30px;height: 30px;background-color: #410202">
                                        <svg style="color: red" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="25" height="25">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                        </svg>
                                    </div>
                                </a>

                            </div>

                        </td>
                    </tr>
                }

            </tbody>



        </table>

    </div>

</div>